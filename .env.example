# Copy this file to .env and fill in your values. NEVER commit .env to git.

# Database
MYSQL_ROOT_PASSWORD=your-strong-db-password

# App secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-random-64-char-string

# Admin account (created automatically on first run)
ADMIN_EMAIL=admin@go-digital.com
ADMIN_PASSWORD=Admin@1234

# Gmail SMTP (use App Password, not your real Gmail password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM=your-gmail@gmail.com

# Frontend public URL (change to your domain or EC2 IP in production)
FRONTEND_URL=http://localhost
