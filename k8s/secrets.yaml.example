# Copy to secrets.yaml and fill in base64-encoded values. NEVER commit secrets.yaml.
# Encode: echo -n "value" | base64
apiVersion: v1
kind: Secret
metadata:
  name: go-digital-secrets
  namespace: go-digital
type: Opaque
data:
  DATABASE_URL: <base64>
  SECRET_KEY: <base64>
  ADMIN_EMAIL: <base64>
  ADMIN_PASSWORD: <base64>
  MAIL_USERNAME: <base64>
  MAIL_PASSWORD: <base64>
  MAIL_FROM: <base64>
  MYSQL_ROOT_PASSWORD: <base64>
